generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum WinnerSide {
  YOUR
  OPPONENT
  DRAW
}

enum FinishType {
  XTREME
  BURST
  OVER
  SPIN
}

model User {
  id                  String       @id @default(cuid())
  username            String       @unique
  displayName         String
  passwordHash        String
  role                UserRole     @default(USER)
  forcePasswordChange Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  combos              Combo[]
  decks               Deck[]
  tournaments         Tournament[]
}

model Combo {
  id         String     @id @default(cuid())
  name       String
  bladeId    String
  ratchetId  String
  bitId      String
  attack     Int
  defense    Int
  stamina    Int
  xtreme     Int
  burst      Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  ownerId    String
  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deckSlots  DeckSlot[]
  yourMatches Match[]   @relation("MatchYourCombo")

  @@unique([ownerId, name])
}

model Deck {
  id         String     @id @default(cuid())
  name       String
  createdAt  DateTime   @default(now())
  ownerId    String
  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  slots      DeckSlot[]

  @@unique([ownerId, name])
}

model DeckSlot {
  id       String   @id @default(cuid())
  slot     Int
  deckId   String
  comboId  String
  deck     Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  combo    Combo    @relation(fields: [comboId], references: [id], onDelete: Restrict)

  @@unique([deckId, slot])
  @@unique([deckId, comboId])
}

model Tournament {
  id         String    @id @default(cuid())
  name       String
  createdAt  DateTime  @default(now())
  ownerId    String
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  matches    Match[]

  @@unique([ownerId, name])
}

model Match {
  id                 String      @id @default(cuid())
  tournamentId       String
  yourComboId        String
  opponentComboName  String
  opponentBladeId    String
  opponentRatchetId  String
  opponentBitId      String
  winner             WinnerSide
  finishType         FinishType
  pointsDelta        Int
  playedAt           DateTime    @default(now())
  tournament         Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  yourCombo          Combo       @relation("MatchYourCombo", fields: [yourComboId], references: [id], onDelete: Restrict)
}
